# ========== 必填 ==========
# 通义千问 / DashScope（LLM 与向量嵌入）
DASHSCOPE_API_KEY=

# 高德 Web 服务（境内 weather_lookup / poi_search）
AMAP_WEBSERVICE_KEY=

# RollingGo（hotel_search / flight_search）
# 申请：https://rollinggo.store/apply
ROLLINGGO_API_KEY=

# ========== 可选 ==========
PORT=5000
FLASK_DEBUG=true
FLASK_RELOAD=false
SECRET_KEY=change-me-to-a-random-string

# 黄历 skill（默认使用 .agents/skills/lao-huangli）
# TRAVEL_AGENT_HUANGLI_SCRIPT=
# TRAVEL_AGENT_HUANGLI_PROFILE=market-folk-v1

# Windows：若 conda 自带 Node 16，可指定系统 Node 18+ 目录
# TRAVEL_AGENT_NODEJS_DIR=C:\Program Files\nodejs

# Windows 终端中文乱码时可设置
# PYTHONUTF8=1
# PYTHONIOENCODING=utf-8
